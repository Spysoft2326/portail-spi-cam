# ============================================
# PORTAIL_SPI_CAM — Variables d'environnement (SQLite)
# ============================================

# Base de données SQLite (fichier local, pas besoin de Docker)
DATABASE_URL="file:./dev.db"

# NextAuth — Secret (générer avec : openssl rand -base64 32)
NEXTAUTH_SECRET="votre_secret_32_caracteres_ici"
NEXTAUTH_URL="http://localhost:3000"

# Configuration application
APP_NAME="Portail SPI Cam"
APP_ENV="development"

# Seuils alertes (par défaut, modifiables en admin)
DEFAULT_SEUIL_ALERTE_PRODUCTION="20"
