// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("AGENT_SAISIE")
  isActive      Boolean   @default(true)
  accounts      Account[]
  sessions      Session[]
  entreprisesCreees Entreprise[] @relation("AgentEntreprises")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Entreprise {
  id                      String       @id @default(uuid())
  referenceSPI            String       @unique
  denomination            String
  sigle                   String?
  formeJuridique          String?
  capitalSocial           Float?
  adresse                 String?
  ville                   String?
  departement             String?
  region                  String
  telephone               String?
  email                   String?
  nomContact              String?
  siteWeb                 String?
  numContribuable         String?
  secteurActivite         String       @default("AUTRE")
  sousSecteur             String?
  produitsPrincipaux      String?
  statut                  String       @default("ACTIF")
  estExportateur          Boolean      @default(false)
  estDansZoneIndustrielle Boolean      @default(false)
  nomZoneIndustrielle     String?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  agentId                 String?
  agent                   User?        @relation("AgentEntreprises", fields: [agentId], references: [id])
  productions             Production[]
}

model Production {
  id                String     @id @default(uuid())
  entrepriseId      String
  entreprise        Entreprise @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  // === Champs de base ===
  produit           String
  quantite          Float?
  unite             String?
  periode           String?
  annee             Int?
  // === Champs détaillés pour le workflow ===
  trimestre         Int?
  productionPhysique Float?
  chiffreAffaires   Float?
  effectifs         Int?
  investissements   Float?
  commentaire       String?
  // === Workflow Agent→Admin→SuperAdmin ===
  statut            String     @default("EN_ATTENTE")
  saisiePar         String?
  validePar         String?
  dateValidation    DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}
