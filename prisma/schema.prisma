// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  role          String    @default("AGENT_SAISIE")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  entreprisesCreees Entreprise[] @relation("AgentEntreprises")
}

model Entreprise {
  id                      String       @id @default(uuid())
  referenceSPI            String       @unique
  denomination            String
  sigle                   String?
  formeJuridique          String?
  capitalSocial           Float?
  adresse                 String?
  ville                   String?
  departement             String?
  region                  String
  telephone               String?
  email                   String?
  nomContact              String?
  siteWeb                 String?
  numContribuable         String?
  secteurActivite         String       @default("AUTRE")
  sousSecteur             String?
  produitsPrincipaux      String?
  statut                  String       @default("ACTIF")
  estExportateur          Boolean      @default(false)
  estDansZoneIndustrielle Boolean      @default(false)
  nomZoneIndustrielle     String?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  // === NOUVEAU : Lien avec l'Agent qui a créé l'entreprise ===
  agentId                 String?
  agent                   User?        @relation("AgentEntreprises", fields: [agentId], references: [id])

  productions             Production[]
}

model Production {
  id            String   @id @default(uuid())
  entrepriseId  String
  entreprise    Entreprise @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  produit       String
  quantite      Float?
  unite         String?
  periode       String?
  annee         Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
