                      <span className="text-gray-600">Base de données</span>
                      <span className="flex items-center gap-1 text-emerald-600">
                        <CheckCircle2 className="w-4 h-4" /> Connectée
                      </span>
                    </div>
                    <div className="flex items-center justify-between text-sm">
                      <span className="text-gray-600">Redis Cache</span>
                      <span className="flex items-center gap-1 text-emerald-600">
                        <CheckCircle2 className="w-4 h-4" /> Actif
                      </span>
                    </div>
                    <div className="flex items-center justify-between text-sm">
                      <span className="text-gray-600">Mode maintenance</span>
                      <span className="flex items-center gap-1 text-emerald-600">
                        <XCircle className="w-4 h-4" /> Inactif
                      </span>
                    </div>
                  </div>
                </div>
                <div className="p-4 bg-[#FCD116]/5 rounded-lg">
                  <h4 className="font-semibold text-gray-900 mb-2">Actions rapides</h4>
                  <div className="grid grid-cols-2 gap-2">
                    <button className="p-2 bg-white rounded border border-gray-200 text-sm hover:bg-gray-50 transition-colors flex items-center gap-2">
                      <Download className="w-4 h-4" /> Export BDD
                    </button>
                    <button className="p-2 bg-white rounded border border-gray-200 text-sm hover:bg-gray-50 transition-colors flex items-center gap-2">
                      <Users className="w-4 h-4" /> Nouvel utilisateur
                    </button>
                    <button className="p-2 bg-white rounded border border-gray-200 text-sm hover:bg-gray-50 transition-colors flex items-center gap-2">
                      <Settings className="w-4 h-4" /> Seuils alertes
                    </button>
                    <button className="p-2 bg-white rounded border border-gray-200 text-sm hover:bg-gray-50 transition-colors flex items-center gap-2">
                      <Database className="w-4 h-4" /> Backup
                    </button>
                  </div>
                </div>
              </div>
            </div>
          )}

          {activeTab === "users" && (
            <div className="overflow-x-auto">
              <table className="w-full">
                <thead>
                  <tr className="border-b border-gray-200">
                    <th className="text-left py-3 px-4 text-sm font-medium text-gray-500">Utilisateur</th>
                    <th className="text-left py-3 px-4 text-sm font-medium text-gray-500">Rôle</th>
                    <th className="text-left py-3 px-4 text-sm font-medium text-gray-500">Statut</th>
                    <th className="text-left py-3 px-4 text-sm font-medium text-gray-500">Dernière connexion</th>
                    <th className="text-left py-3 px-4 text-sm font-medium text-gray-500">Actions</th>
                  </tr>
                </thead>
                <tbody className="divide-y divide-gray-100">
                  {users.map((user) => (
                    <tr key={user.id} className="hover:bg-gray-50">
                      <td className="py-3 px-4">
                        <div>
                          <p className="text-sm font-medium text-gray-900">{user.name}</p>
                          <p className="text-xs text-gray-500">{user.email}</p>
                        </div>
                      </td>
                      <td className="py-3 px-4">
                        <span className={`px-2 py-1 rounded-full text-xs font-medium ${
                          user.role === "SUPER_ADMIN" ? "bg-purple-100 text-purple-700" :
                          user.role === "ADMIN" ? "bg-blue-100 text-blue-700" :
                          "bg-gray-100 text-gray-700"
                        }`}>
                          {user.role === "SUPER_ADMIN" ? "Super-Admin" :
                           user.role === "ADMIN" ? "Admin" : "Agent"}
                        </span>
                      </td>
                      <td className="py-3 px-4">
                        <span className={`flex items-center gap-1 text-xs ${
                          user.status === "active" ? "text-emerald-600" : "text-gray-500"
                        }`}>
                          <span className={`w-2 h-2 rounded-full ${
                            user.status === "active" ? "bg-emerald-500" : "bg-gray-400"
                          }`} />
                          {user.status === "active" ? "Actif" : "Inactif"}
                        </span>
                      </td>
                      <td className="py-3 px-4 text-sm text-gray-500">{user.lastLogin}</td>
                      <td className="py-3 px-4">
                        <div className="flex items-center gap-2">
                          <button className="text-sm text-[#007A3D] hover:text-[#006633]">Éditer</button>
                          <button className="text-sm text-red-600 hover:text-red-700">Désactiver</button>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}

          {activeTab === "logs" && (
            <div className="overflow-x-auto">
              <table className="w-full">
                <thead>
                  <tr className="border-b border-gray-200">
                    <th className="text-left py-3 px-4 text-sm font-medium text-gray-500">Date</th>
                    <th className="text-left py-3 px-4 text-sm font-medium text-gray-500">Utilisateur</th>
                    <th className="text-left py-3 px-4 text-sm font-medium text-gray-500">Action</th>
                    <th className="text-left py-3 px-4 text-sm font-medium text-gray-500">Entité</th>
                    <th className="text-left py-3 px-4 text-sm font-medium text-gray-500">ID</th>
                  </tr>
                </thead>
                <tbody className="divide-y divide-gray-100">
                  {auditLogs.map((log) => (
                    <tr key={log.id} className="hover:bg-gray-50">
                      <td className="py-3 px-4 text-sm text-gray-500">{log.date}</td>
                      <td className="py-3 px-4 text-sm text-gray-900">{log.user}</td>
                      <td className="py-3 px-4">
                        <span className={`px-2 py-1 rounded text-xs font-medium ${
                          log.action === "CREATE" ? "bg-emerald-100 text-emerald-700" :
                          log.action === "UPDATE" ? "bg-blue-100 text-blue-700" :
                          log.action === "DELETE" ? "bg-red-100 text-red-700" :
                          log.action === "VALIDATE" ? "bg-[#007A3D]/10 text-[#007A3D]" :
                          "bg-gray-100 text-gray-700"
                        }`}>
                          {log.action}
                        </span>
                      </td>
                      <td className="py-3 px-4 text-sm text-gray-500">{log.entity}</td>
                      <td className="py-3 px-4 text-sm text-gray-500 font-mono">{log.entityId}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}

          {activeTab === "config" && (
            <div className="space-y-4 max-w-2xl">
              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">Année en cours</label>
                  <input type="number" defaultValue={2026} className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">Seuil alerte production (%)</label>
                  <input type="number" defaultValue={20} className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">Email notifications</label>
                  <input type="email" defaultValue="admin@spi-cam.cm" className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">Fréquence rappel (CRON)</label>
                  <input type="text" defaultValue="0 0 1 * *" className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
              </div>
              <div className="flex items-center gap-2 pt-4">
                <button className="px-4 py-2 bg-[#007A3D] text-white rounded-lg text-sm font-medium hover:bg-[#006633] transition-colors">
                  Sauvegarder
                </button>
                <button className="px-4 py-2 border border-gray-300 text-gray-700 rounded-lg text-sm hover:bg-gray-50 transition-colors">
                  Réinitialiser
                </button>
              </div>
            </div>
          )}
