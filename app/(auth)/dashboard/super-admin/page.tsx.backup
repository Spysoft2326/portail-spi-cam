"use client";

import { useState } from "react";
import Link from "next/link";
import {
  Users,
  Settings,
  Shield,
  Database,
  Activity,
  AlertTriangle,
  CheckCircle2,
  XCircle,
  Download,
} from "lucide-react";

export default function SuperAdminDashboard() {
  const [activeTab, setActiveTab] = useState("overview");

  const systemStats = [
    { label: "Utilisateurs", value: "24", icon: Users, color: "bg-blue-600" },
    { label: "Entreprises", value: "100", icon: Database, color: "bg-[#007A3D]" },
    { label: "Données production", value: "1,247", icon: Activity, color: "bg-purple-600" },
    { label: "Alertes système", value: "3", icon: AlertTriangle, color: "bg-[#CE1126]" },
  ];

  const users = [
    { id: 1, name: "Super Admin", email: "superadmin@spi-cam.cm", role: "SUPER_ADMIN", status: "active", lastLogin: "03/06/2026 14:30" },
    { id: 2, name: "Responsable Analyse", email: "admin@spi-cam.cm", role: "ADMIN", status: "active", lastLogin: "03/06/2026 10:15" },
    { id: 3, name: "Agent Douala", email: "agent1@spi-cam.cm", role: "AGENT_SAISIE", status: "active", lastLogin: "03/06/2026 09:00" },
    { id: 4, name: "Agent Yaoundé", email: "agent2@spi-cam.cm", role: "AGENT_SAISIE", status: "inactive", lastLogin: "01/06/2026 16:45" },
  ];

  const auditLogs = [
    { id: 1, user: "admin@spi-cam.cm", action: "VALIDATE", entity: "ProductionData", entityId: "123", date: "03/06/2026 14:20" },
    { id: 2, user: "agent1@spi-cam.cm", action: "CREATE", entity: "ProductionData", entityId: "124", date: "03/06/2026 11:30" },
    { id: 3, user: "superadmin@spi-cam.cm", action: "UPDATE", entity: "ConfigSystem", entityId: "1", date: "02/06/2026 17:00" },
    { id: 4, user: "admin@spi-cam.cm", action: "REJECT", entity: "ProductionData", entityId: "122", date: "02/06/2026 15:45" },
  ];

  return (
    <div className="space-y-6">
      <div>
        <h2 className="text-2xl font-bold text-gray-900">Administration Système</h2>
        <p className="text-sm text-gray-500 mt-1">Configuration et supervision globale</p>
      </div>

      {/* System Stats */}
      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {systemStats.map((stat) => (
          <div key={stat.label} className="bg-white rounded-xl p-5 border border-gray-200">
