{
  "name": "portail-spi-cam",
  "version": "1.0.0",
  "description": "Portail de Suivi de la Production Industrielle du Cameroun",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "build": "next build",
    "start": "next start -p 3000",
    "dev": "next dev",
    "seed": "node scripts/seed-users.js && node scripts/seed-enterprises.js",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node scripts/seed-users.js && node scripts/seed-enterprises.js",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "setup": "npm install && npm run db:generate && npm run db:push && npm run db:seed && npm run dev"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.0.0",
    "@hookform/resolvers": "^3.4.0",
    "@prisma/client": "^5.22.0",
    "@react-pdf/renderer": "^3.4.0",
    "@tanstack/react-table": "^8.17.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.378.0",
    "next": "^14.2.0",
    "next-auth": "^4.24.7",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.51.0",
    "react-leaflet": "^4.2.1",
    "recharts": "^2.12.0",
    "tailwind-merge": "^2.3.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0"
  }
}

